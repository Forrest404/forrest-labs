# NOUR — Network for Operational Updates & Response — Environment Variables
# Copy this file to .env.local and fill in real values before running locally.
# On Vercel: add each variable in Project Settings → Environment Variables.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — server-side only, never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Found in: mapbox.com → Account → Access tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── Push notifications (ntfy.sh) ──────────────────────────────────────────────
# The private channel name the founder's phone subscribes to
NTFY_CHANNEL=your-private-channel-name

# ── Admin auth ────────────────────────────────────────────────────────────────
# Secret token used to authorise approve/reject calls from the founder's phone.
# Embedded as ?key= in ntfy action URLs — use a long random string.
# Generate with: openssl rand -hex 32
REVIEW_SECRET_KEY=your_review_secret_32_hex_chars

# ── App URL ───────────────────────────────────────────────────────────────────
# Full public URL of the deployed frontend (no trailing slash)
NEXT_PUBLIC_APP_URL=https://www.noursystems.org

# ── Python face-blur worker (Railway) ─────────────────────────────────────────
# URL of the deployed Railway service
WORKER_URL=https://your-worker.up.railway.app

# ── Transactional email (Resend) — OPTIONAL ───────────────────────────────────
# Server-only. Without these, email features degrade to a clear "not configured"
# state rather than failing silently (approvals/invites/resets still record server-side).
# 1) Create a key at resend.com → API Keys.
# 2) Verify the noursystems.org domain at resend.com → Domains, then add the DNS
#    records it shows (MX + SPF TXT on send.noursystems.org, DKIM TXT
#    resend._domainkey.noursystems.org) at your registrar, plus a DMARC TXT at
#    _dmarc.noursystems.org. Email will not deliver reliably until those verify.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=NOUR <noreply@noursystems.org>
# Optional: where admin 2FA security-notice emails go (admin is an env-based account with
# no stored email). If unset, admin 2FA still works — notices are just on-screen only.
ADMIN_EMAIL=ops@noursystems.org
